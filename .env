# IBKR_PASSWORD=your_ibkr_password
#
# # Webhook for alerts (Discord/Slack)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR_WEBHOOK
